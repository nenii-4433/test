# Server
PORT=3000
STORE_URL=http://localhost:3000

# SafePay (https://getsafepay.com/dashboard)
SAFEPAY_ENV=sandbox
SAFEPAY_PUBLIC_KEY=your_public_key_here
SAFEPAY_SECRET_KEY=your_secret_key_here
SAFEPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Email (Gmail example — use App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Your Store <your-email@gmail.com>

# Admin dashboard login
ADMIN_PASSWORD=change-this-password
